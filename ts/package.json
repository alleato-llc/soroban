{
  "name": "@alleato/anzan",
  "version": "0.1.0",
  "description": "Anzan, the exact calculation language — the Rust engine compiled to WebAssembly, wrapped in a typed TypeScript SDK and CLI.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alleato-llc/soroban.git",
    "directory": "ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "anzan": "dist/cli/anzan.js"
  },
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "spec": "NODE_OPTIONS=\"--import tsx\" cucumber-js --config cucumber.mjs",
    "anzan": "tsx src/cli/anzan.ts",
    "build:wasm": "cd ../rust/wasm && wasm-pack build --target nodejs && wasm-pack build --target web --out-dir pkg-web && cd ../../ts && node scripts/vendor-wasm.mjs"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
