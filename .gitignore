# Generated by XcodeGen — regenerate with `xcodegen generate`
*.xcodeproj

# SwiftPM
.build/
.swiftpm/

# Xcode
DerivedData/
xcuserdata/
# xcodebuild's default SYMROOT when built from swift/ without a derived-data path
build/

# macOS
.DS_Store

# Derived app icon PNGs — regenerated by scripts/generate_icon.py pre-build
swift/App/Resources/Assets.xcassets/AppIcon.appiconset/*.png

# Stray Astro/Vite artifacts (the site lives in site/; site/.gitignore covers its own)
node_modules/
.astro/

# Python bytecode (scripts/)
__pycache__/

# Local Gherkin HTML reports (CI uploads its own as artifacts)
pickle-report.html
pickle-spec.html
session-report.html

# Signing material — NEVER commit (lives in the keychain / GitHub secrets)
*.p12
*.cer
*.certSigningRequest
