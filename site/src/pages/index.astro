---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";

const links = {
    // The notarized dmg, served straight from the latest GitHub Release.
    // salpa publish attaches a versionless Soroban.dmg, so this URL is stable
    // across versions (GitHub redirects /latest/ to the newest release).
    download: "https://github.com/alleato-llc/soroban/releases/latest/download/Soroban.dmg",
    source: "https://github.com/alleato-llc/soroban",
    donate: "https://buymeacoffee.com/alleato",
    // The Anzan language spec — /anzan renders the repo's canonical
    // docs/ANZAN.md at build time (see src/content.config.ts), so the site
    // can never drift from the engine.
    spec: "/anzan",
    // The Living Specification — every behavior as verified Given/When/Then
    // prose, generated from the engine's Gherkin suite (scripts/
    // generate-living-spec.sh), with the full test report one click deeper.
    verified: "/spec.html",
};
---

<Layout
    title="Soroban・算盤 — an exact calculator with a spreadsheet attached"
    description="An exact calculator for macOS with a mini-spreadsheet attached, built on a 50-digit exact decimal engine. 0.1 + 0.2 is exactly 0.3. Free and open source."
>
    <div class="wrap">
        <section class="hero">
            <h1>Soroban<span class="kanji">・算盤</span></h1>
            <p class="tag">An exact calculator with a spreadsheet attached.</p>
            <p class="sub">
                Type expressions into a scrolling log, or flip to a 26×1,000
                grid where cells hold formulas, controls, and definitions.
                Underneath: an arbitrary-precision decimal engine — <code
                    >0.1 + 0.2</code
                > is exactly
                <code>0.3</code>, and money math never picks up floating-point
                drift.
            </p>
            <div class="cta">
                <a class="button primary" href={links.download}
                    >Download for macOS</a
                >
                <a class="button quiet" href={links.source}>View source</a>
            </div>
            <p class="fine">
                Free &amp; open source · macOS 14+ · saves plain, diffable files
            </p>
            <p class="fine">
                Every behavior is a written, <a href={links.verified}
                    >continuously-verified specification</a
                >.
            </p>

            <!-- Real app screenshots in a theme-matched carousel: every shot
                 for the current theme cycles (dark has more than light), the
                 page-theme set is shown via CSS. Single click pauses/plays;
                 double click maximizes (Esc / click-away / double-click to
                 exit). Dots are built per theme. Honors reduced-motion. -->
            <div class="hero-shot" data-carousel>
                <div class="shots">
                    <img class="shot shot-dark is-active" data-slide="0"
                        src="/screenshots/log-dark.png"
                        alt="Soroban's calculation log with computed results"
                        width="3056" height="1970" loading="eager" />
                    <img class="shot shot-dark" data-slide="1"
                        src="/screenshots/log-inspector-dark.png"
                        alt="Soroban's calculation log with the environment inspector and autocomplete"
                        width="3056" height="1970" loading="lazy" />
                    <img class="shot shot-dark" data-slide="2"
                        src="/screenshots/grid-dark.png"
                        alt="Soroban's spreadsheet grid: a mortgage model with formulas and controls"
                        width="3056" height="1970" loading="lazy" />
                    <img class="shot shot-light is-active" data-slide="0"
                        src="/screenshots/log-light.png"
                        alt="Soroban's calculation log with computed results"
                        width="3056" height="1970" loading="eager" />
                    <img class="shot shot-light" data-slide="1"
                        src="/screenshots/grid-light.png"
                        alt="Soroban's spreadsheet grid: a mortgage model with formulas and controls"
                        width="3056" height="1970" loading="lazy" />
                    <img class="shot shot-light" data-slide="2"
                        src="/screenshots/grid-inspector-light.png"
                        alt="Soroban's spreadsheet grid with the environment inspector"
                        width="3056" height="1970" loading="lazy" />
                </div>
                <div class="dots" aria-label="Screenshot navigation"></div>
            </div>
            <div class="lightbox" aria-hidden="true">
                <img class="lightbox-img" alt="" />
            </div>

            <script>
                // Theme-aware screenshot carousel. It cycles every shot for
                // the CURRENT theme (CSS hides the other theme), rebuilding
                // its dots when the theme toggles. Single click = pause/play;
                // double click = maximize; Esc / click-away / double-click
                // exits. Reduced-motion users start paused.
                const root = document.querySelector<HTMLElement>(".hero-shot[data-carousel]");
                const lightbox = document.querySelector<HTMLElement>(".lightbox");
                if (root && lightbox) {
                    const shots = root.querySelector<HTMLElement>(".shots")!;
                    const dotsWrap = root.querySelector<HTMLElement>(".dots")!;
                    const lightImg = lightbox.querySelector<HTMLImageElement>(".lightbox-img")!;
                    let index = 0;
                    let timer: number | undefined;
                    let clickTimer: number | undefined;
                    let wasPaused = false;
                    let paused = matchMedia("(prefers-reduced-motion: reduce)").matches;

                    const theme = () =>
                        document.documentElement.dataset.theme === "light" ? "light" : "dark";
                    const slides = () =>
                        [...root.querySelectorAll<HTMLImageElement>(`.shot-${theme()}`)].sort(
                            (a, b) => Number(a.dataset.slide) - Number(b.dataset.slide),
                        );

                    const render = () => {
                        const list = slides();
                        index = ((index % list.length) + list.length) % list.length;
                        root.querySelectorAll(".shot").forEach((s) => s.classList.remove("is-active"));
                        list[index]?.classList.add("is-active");
                        [...dotsWrap.children].forEach((d, k) =>
                            d.classList.toggle("is-active", k === index),
                        );
                    };
                    const buildDots = () => {
                        dotsWrap.innerHTML = "";
                        slides().forEach((_, k) => {
                            const b = document.createElement("button");
                            b.className = "dot" + (k === index ? " is-active" : "");
                            b.setAttribute("aria-label", `Show screenshot ${k + 1}`);
                            b.addEventListener("click", (e) => {
                                e.stopPropagation();
                                pause();
                                index = k;
                                render();
                            });
                            dotsWrap.appendChild(b);
                        });
                    };
                    const stop = () => {
                        if (timer) clearInterval(timer);
                        timer = undefined;
                    };
                    const play = () => {
                        stop();
                        if (!paused)
                            timer = window.setInterval(() => {
                                index += 1;
                                render();
                            }, 5500);
                    };
                    const pause = () => {
                        paused = true;
                        root.classList.add("is-paused");
                        stop();
                    };
                    const togglePlay = () => {
                        paused = !paused;
                        root.classList.toggle("is-paused", paused);
                        paused ? stop() : play();
                    };

                    const maximize = () => {
                        const list = slides();
                        lightImg.src = list[index].src;
                        lightImg.alt = list[index].alt;
                        lightbox.classList.add("open");
                        lightbox.setAttribute("aria-hidden", "false");
                        wasPaused = paused;
                        pause();
                    };
                    const exitMax = () => {
                        if (!lightbox.classList.contains("open")) return;
                        lightbox.classList.remove("open");
                        lightbox.setAttribute("aria-hidden", "true");
                        paused = wasPaused;
                        root.classList.toggle("is-paused", paused);
                        play();
                    };

                    // Single click pauses/plays; a double click cancels the
                    // pending single action and maximizes instead.
                    shots.addEventListener("click", () => {
                        clearTimeout(clickTimer);
                        clickTimer = window.setTimeout(togglePlay, 250);
                    });
                    shots.addEventListener("dblclick", () => {
                        clearTimeout(clickTimer);
                        maximize();
                    });

                    lightbox.addEventListener("click", (e) => {
                        if (e.target === lightbox) exitMax(); // click away (backdrop)
                    });
                    lightbox.addEventListener("dblclick", exitMax);
                    document.addEventListener("keydown", (e) => {
                        if (e.key === "Escape") exitMax();
                    });

                    new MutationObserver(() => {
                        buildDots();
                        render();
                    }).observe(document.documentElement, {
                        attributes: true,
                        attributeFilter: ["data-theme"],
                    });

                    buildDots();
                    render();
                    play();
                }
            </script>
        </section>

        <section id="features">
            <h2>Built around one idea: be exact, then stay out of the way</h2>
            <p class="section-lede">
                Nine things Soroban does well. Tap a card to jump to the
                details.
            </p>
            <div class="features summary">
                <Card title="Exact arithmetic" href="#feat-exact" scopes={["log", "grid", "cli"]}>
                    A 50-digit exact decimal engine — <code>0.1 + 0.2</code> is
                    exactly <code>0.3</code> — plus a money type and checked
                    fixed-width integers.
                </Card>
                <Card title="The Anzan language" href="#feat-language" scopes={["log", "grid", "cli"]}>
                    Custom functions, recursion, data structures, lambdas, and
                    namespaces — a real little language, fully specified.
                </Card>
                <Card title="Log + grid, one engine" href="#feat-grid" scopes={["log", "grid"]}>
                    A scrolling calculator log and a 26×1,000 grid that share
                    every variable, function, and cell reference.
                </Card>
                <Card title="Programmer mode & bit editor" href="#feat-bits" scopes={["log", "grid", "cli"]}>
                    A C-style dialect and a clickable binary bit editor with
                    reusable, color-coded bit-field formats.
                </Card>
                <Card title="Live what-if controls" href="#feat-controls" scopes={["grid"]}>
                    Sliders, steppers, checkboxes, and dropdowns right in the
                    cells — the model recalculates as you drag.
                </Card>
                <Card title="Data sheets at scale" href="#feat-data" scopes={["grid"]}>
                    Import 100,000-row CSVs into SQLite-backed sheets; formulas
                    reach every row, opens stay instant.
                </Card>
                <Card title="In your terminal" href="#feat-cli" scopes={["cli"]}>
                    The whole language ships as a <code>soroban</code> CLI:
                    REPL, pipes, and real exit codes.
                </Card>
                <Card title="A plain file format" href="#feat-file" scopes={["log", "grid"]}>
                    <code>.soroban</code> is documented JSON (+ SQLite) —
                    diffable, scriptable, hand-editable. CSV in and out.
                </Card>
                <Card title="Make it yours" href="#feat-themes">
                    Ten built-in themes, or drop in your own. This very site is
                    wearing two of them.
                </Card>
            </div>
        </section>

        <div class="feature-detail">
            <nav class="feature-nav" aria-label="Features">
                <a href="#feat-exact">Exact</a>
                <a href="#feat-language">Language</a>
                <a href="#feat-grid">Log + grid</a>
                <a href="#feat-bits">Programmer</a>
                <a href="#feat-controls">Controls</a>
                <a href="#feat-data">Data</a>
                <a href="#feat-cli">CLI</a>
                <a href="#feat-file">File</a>
                <a href="#feat-themes">Themes</a>
            </nav>

            <section class="feature" id="feat-exact">
                <h2>Exact arithmetic</h2>
                <p>
                    Underneath everything is an arbitrary-precision decimal
                    engine. <code>+ − ×</code> and integer powers are
                    <em>exact</em>; division carries 50 significant digits with
                    banker's rounding. <code>0.1 + 0.2</code> is exactly
                    <code>0.3</code>, and Machin's 1706 formula recovers π to 51
                    places in three typed lines — money math never picks up
                    floating-point drift.
                </p>
                <p>
                    When you need a <strong>bounded</strong> type, it stays exact
                    but <em>checked</em>. <code>Decimal(10.5, 5, 2)</code> is
                    <code>10.50</code> — SQL <code>DECIMAL(p, s)</code>, the money
                    type: rounds to the scale, errors on precision overflow
                    instead of silently dropping digits (banker's rounding, or
                    <code>Rounding.HalfUp</code>). <code>Int32(255)</code>,
                    <code>UInt8(8)</code> are integers at 8–256 bits, signed or
                    unsigned — <code>Int8(100) + Int8(100)</code> is an overflow
                    error, never a silent wraparound.
                </p>
                <p>
                    And the everyday formulas are built in across domains:
                    statistics (<code>median</code>, <code>stdev</code>), algebra
                    (<code>sqrt</code>, <code>gcd</code>), logic (<code>if</code>,
                    <code>and</code>, <code>or</code>), finance (<code>pmt</code>,
                    <code>irr</code>, <code>xirr</code>), and dates
                    (<code>edate</code>, <code>days</code>).
                </p>
            </section>

            <section class="feature" id="feat-language">
                <h2>The Anzan language</h2>
                <p>
                    <a href={links.spec}>Anzan</a> — Soroban's expression language
                    — is a small but real language. Define a function and it's
                    immediately usable: <code>f(x) = x * 2</code>. Functions
                    recurse, take LaTeX-style reductions
                    (<code>∑</code>/<code>∏</code>), and document themselves from a
                    trailing <code># comment</code>.
                </p>
                <p>
                    It has first-class data — arrays, maps, strings, booleans, and
                    <code>data</code> records — plus higher-order functions and
                    lambdas (<code>map(x -&gt; x^2, [1, 2, 3])</code>). Group your
                    own types and functions into <strong>namespaces</strong>
                    (<code>Geo::Point</code>, <code>import Geo</code>), nesting and
                    all. Every built-in has a man page (<code>man pmt</code>, or ⌘/
                    for a searchable reference), and every documented example is
                    evaluated by the test suite — so the docs can't rot.
                </p>
                <p>
                    <a class="button quiet" href={links.spec}>Read the language spec</a>
                </p>
            </section>

            <section class="feature" id="feat-grid">
                <h2>Log + grid, one engine</h2>
                <p>
                    Type into a scrolling calculation log, or flip to a 26×1,000
                    spreadsheet grid (⌘\). They share one engine: reference
                    <code>B:1</code> from the log, use <code>rate</code> in a cell,
                    sum a column with <code>sum(A:1..A:9)</code> — across
                    worksheets too (<code>Budget!A:1</code>).
                </p>
                <p>
                    Name a cell and write <code>'Projected Rate' * 12</code>
                    instead of <code>B:7</code>; renames rewrite every referencing
                    formula. A formula can even inspect the workbook itself —
                    <code>cell("A", 1).value</code>,
                    <code>Workbook.worksheets["Budget"]</code>,
                    <code>sheetNames()</code> — with reads kept live, and log
                    commands like <code>updateCell</code> /
                    <code>addWorksheet</code> changing it one undo step at a time.
                </p>
            </section>

            <section class="feature" id="feat-bits">
                <h2>Programmer mode &amp; the bit editor</h2>
                <p>
                    Flip the log to <strong>Programmer mode</strong> and the
                    overloaded glyphs read like C: <code>^</code> is XOR,
                    <code>&amp;</code> <code>|</code> <code>&lt;&lt;</code>
                    <code>&gt;&gt;</code> <code>~</code> are bitwise,
                    <code>%</code> is modulo. It's a display <em>dialect</em>, not
                    a semantic switch — the stored formula stays canonical, so it
                    can never mean two things. <code>:mode programmer</code> in the
                    CLI; a picker in the app.
                </p>
                <p>
                    The app adds a macOS-Calculator-style <strong>binary bit
                    editor</strong>: a number becomes a clickable register, and a
                    reusable <strong>bit-field format</strong> labels its bit
                    ranges — numeric, per-bit flags (<code>r-x</code>), or an enum
                    that decodes a value to a label. Build one visually: drag the
                    bits to carve a group, name it, color it, and save. Formats
                    persist as ordinary typed values you can read and edit.
                </p>
            </section>

            <section class="feature" id="feat-controls">
                <h2>Live what-if controls</h2>
                <p>
                    <code>rate = slider(0.08, 0, 0.2)</code> renders as a draggable
                    slider right in its cell — plus steppers, checkboxes, and
                    dropdowns. The whole model recalculates as you drag, with one
                    undo step on release. The control's value <em>is</em> the
                    stored literal, so it's still a plain, inspectable formula.
                </p>
            </section>

            <section class="feature" id="feat-data">
                <h2>Data sheets at scale</h2>
                <p>
                    Import a 100,000-row CSV into a SQLite-backed sheet that lives
                    inside the document. Formulas reach every row
                    (<code>sum(Sales!C:2..C:100000)</code>), and opens stay instant
                    — the grid renders a window, the database holds the rows.
                </p>
            </section>

            <section class="feature" id="feat-cli">
                <h2>In your terminal</h2>
                <p>
                    The full language ships as a <code>soroban</code> CLI. Run it
                    as an Anzan REPL with tab completion, signature hints, and
                    persistent history; pass an expression as an argument; or pipe
                    it (<code>echo "fact(25)" | soroban</code>) and script against
                    real exit codes. Same engine, same column-accurate error
                    carets — just no grid.
                </p>
            </section>

            <section class="feature" id="feat-file">
                <h2>A plain file format</h2>
                <p>
                    <code>.soroban</code> is a documented package of pretty-printed
                    JSON (plus SQLite for data sheets) — diffable in git,
                    scriptable, hand-editable. Every behavior of the format is
                    written down, and CSV goes in and out. Your work isn't trapped
                    in a binary blob.
                </p>
            </section>

            <section class="feature" id="feat-themes">
                <h2>Make it yours</h2>
                <p>
                    Ten built-in themes — Solarized, Dracula, Nord, gruvbox… — or
                    drop a small JSON theme into Application Support to make your
                    own. This very site is wearing two of them; toggle it in the
                    header.
                </p>
            </section>
        </div>

        <script>
            // Scroll-spy: mark the feature-nav link whose section is in view.
            const navLinks = [
                ...document.querySelectorAll<HTMLAnchorElement>(".feature-nav a"),
            ];
            const byId = new Map(
                navLinks.map((a) => [a.getAttribute("href")!.slice(1), a]),
            );
            const sections = [
                ...document.querySelectorAll<HTMLElement>(".feature"),
            ];
            if (navLinks.length && sections.length) {
                const setCurrent = (id: string) =>
                    navLinks.forEach((a) =>
                        a === byId.get(id)
                            ? a.setAttribute("aria-current", "true")
                            : a.removeAttribute("aria-current"),
                    );
                const obs = new IntersectionObserver(
                    (entries) => {
                        for (const e of entries)
                            if (e.isIntersecting) setCurrent((e.target as HTMLElement).id);
                    },
                    { rootMargin: "-30% 0px -60% 0px", threshold: 0 },
                );
                sections.forEach((s) => obs.observe(s));
            }
        </script>

        <section class="support" id="source">
            <div class="cols">
                <div>
                    <h2>Open source</h2>
                    <p>
                        Soroban is developed in the open — the calculation
                        engine is a standalone, UI-free Swift package with
                        hundreds of tests and executable Gherkin specs,
                        including the mathematical identities that certify it
                        (π via Machin, Nicomachus, the Gregorian leap rule…).
                        Read it, audit it, build it yourself.
                    </p>
                    <p>
                        <a class="button quiet" href={links.source}
                            >Source &amp; issues</a
                        >
                    </p>
                </div>
                <div id="donate">
                    <h2>Donations</h2>
                    <p>
                        The app is free and always will be. If it earns a place
                        in your workflow, a donation keeps the work moving — and
                        is genuinely appreciated.
                    </p>
                    <p style="display:flex; gap:0.6rem; flex-wrap:wrap">
                        <a class="button primary" href={links.donate}
                            >Buy me a coffee</a
                        >
                    </p>
                </div>
            </div>
        </section>
    </div>
</Layout>
