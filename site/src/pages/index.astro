---
import Layout from "../layouts/Layout.astro";
import Card from "../components/Card.astro";
import Repl from "../components/Repl.tsx";
import Download from "../components/Download.tsx";
import { resolveDownloads } from "../lib/releases";

// Resolve each track's newest release → stable asset URLs, at build time.
// Passed into the <Download> island, which picks the right button per OS/arch.
const downloads = await resolveDownloads();

const links = {
    source: "https://github.com/alleato-llc/soroban",
    donate: "https://buymeacoffee.com/alleato",
    // The Anzan language spec — /anzan renders the repo's canonical
    // docs/ANZAN.md at build time (see src/content.config.ts), so the site
    // can never drift from the engine.
    spec: "/anzan",
    // The Living Specification — every behavior as verified Given/When/Then
    // prose, generated from the engine's Gherkin suite (scripts/
    // generate_living_spec.py), with the full test report one click deeper.
    verified: "/spec.html",
    // The two engines' test reports against that one shared spec: the native
    // Swift engine (PickleKit) and the cross-platform Rust engine (cucumber →
    // scripts/rust-report.mjs).
    swiftReport: "/report.html",
    rustReport: "/rust-report.html",
    // Cross-engine micro-benchmarks — the Rust and Swift engines evaluating the
    // same Anzan workloads, measured same-box/same-run (bench/, published by
    // deploy-site.yml). A relative comparison; absolute numbers are trend-only.
    perf: "/perf.html",
};
---

<Layout
    title="Soroban・算盤 — an exact calculator with a spreadsheet attached"
    description="An exact calculator with a mini-spreadsheet attached, for macOS, Windows, and Linux — built on a 50-digit exact decimal engine. 0.1 + 0.2 is exactly 0.3. Free and open source."
>
    <div class="wrap">
        <section class="hero">
            <h1>Soroban<span class="kanji">・算盤</span></h1>
            <p class="tag">An exact calculator with a spreadsheet attached.</p>
            <p class="sub">
                Type expressions into a scrolling log, or flip to a 26×1,000
                grid where cells hold formulas, controls, and definitions.
                Underneath: an arbitrary-precision decimal engine — <code
                    >0.1 + 0.2</code
                > is exactly
                <code>0.3</code>, and money math never picks up floating-point
                drift.
            </p>
            <div class="cta">
                <Download client:load {...downloads} />
                <a class="button quiet" href={links.source}>View source</a>
            </div>
            <p class="fine">
                Free &amp; open source · macOS 15+ · Windows · Linux · saves
                plain, diffable files
            </p>
            <p class="fine">
                Every behavior is a written, <a href={links.verified}
                    >continuously-verified specification</a
                > — proven by both the <a href={links.swiftReport}
                    >native (Swift)</a
                > and <a href={links.rustReport}>cross-platform (Rust)</a>
                engines against one shared spec — and continuously <a
                    href={links.perf}>benchmarked</a
                > across both.
            </p>

            <!-- Real app screenshots in a theme-matched carousel with TWO
                 build sets: the native (Swift) app and the cross-platform
                 (Rust) app. The segmented toggle picks the build; CSS shows
                 only the current build+theme; every shot for that pair cycles.
                 Single click pauses/plays; double click maximizes (Esc /
                 click-away / double-click to exit). Dots rebuild per set.
                 Honors reduced-motion. -->
            <div class="hero-shot" data-carousel data-build="native">
                <div class="build-toggle" role="tablist" aria-label="Which build to preview">
                    <button class="bt-opt is-active" data-build="native" role="tab">Native · macOS</button>
                    <button class="bt-opt" data-build="cross" role="tab">Cross-platform</button>
                    <button class="bt-opt" data-build="live" role="tab">Live · try it</button>
                </div>
                <div class="shots">
                    <!-- Native (Swift/macOS) -->
                    <img class="shot shot-dark is-active" data-build="native" data-slide="0"
                        src="/screenshots/log-dark.png"
                        alt="Soroban's calculation log with computed results"
                        width="3056" height="1970" loading="eager" />
                    <img class="shot shot-dark" data-build="native" data-slide="1"
                        src="/screenshots/log-inspector-dark.png"
                        alt="Soroban's calculation log with the environment inspector and autocomplete"
                        width="3056" height="1970" loading="lazy" />
                    <img class="shot shot-dark" data-build="native" data-slide="2"
                        src="/screenshots/grid-dark.png"
                        alt="Soroban's spreadsheet grid: a mortgage model with formulas and controls"
                        width="3056" height="1970" loading="lazy" />
                    <img class="shot shot-light is-active" data-build="native" data-slide="0"
                        src="/screenshots/log-light.png"
                        alt="Soroban's calculation log with computed results"
                        width="3056" height="1970" loading="eager" />
                    <img class="shot shot-light" data-build="native" data-slide="1"
                        src="/screenshots/grid-light.png"
                        alt="Soroban's spreadsheet grid: a mortgage model with formulas and controls"
                        width="3056" height="1970" loading="lazy" />
                    <img class="shot shot-light" data-build="native" data-slide="2"
                        src="/screenshots/grid-inspector-light.png"
                        alt="Soroban's spreadsheet grid with the environment inspector"
                        width="3056" height="1970" loading="lazy" />
                    <!-- Cross-platform (Rust/iced) -->
                    <img class="shot shot-dark" data-build="cross" data-slide="0"
                        src="/screenshots/rust-log-dark.png"
                        alt="The cross-platform Rust app's calculation log with computed results"
                        width="2080" height="1360" loading="lazy" />
                    <img class="shot shot-dark" data-build="cross" data-slide="1"
                        src="/screenshots/rust-log-inspector-dark.png"
                        alt="The cross-platform Rust app's log with the environment inspector"
                        width="2080" height="1360" loading="lazy" />
                    <img class="shot shot-dark" data-build="cross" data-slide="2"
                        src="/screenshots/rust-grid-dark.png"
                        alt="The cross-platform Rust app's grid: a mortgage model with a live slider control"
                        width="2080" height="1360" loading="lazy" />
                    <img class="shot shot-dark" data-build="cross" data-slide="3"
                        src="/screenshots/rust-grid-inspector-dark.png"
                        alt="The cross-platform Rust app's grid with the environment inspector"
                        width="2080" height="1360" loading="lazy" />
                    <img class="shot shot-light" data-build="cross" data-slide="0"
                        src="/screenshots/rust-log-light.png"
                        alt="The cross-platform Rust app's calculation log with computed results"
                        width="2080" height="1360" loading="lazy" />
                    <img class="shot shot-light" data-build="cross" data-slide="1"
                        src="/screenshots/rust-log-inspector-light.png"
                        alt="The cross-platform Rust app's log with the environment inspector"
                        width="2080" height="1360" loading="lazy" />
                    <img class="shot shot-light" data-build="cross" data-slide="2"
                        src="/screenshots/rust-grid-light.png"
                        alt="The cross-platform Rust app's grid: a mortgage model with a live slider control"
                        width="2080" height="1360" loading="lazy" />
                    <img class="shot shot-light" data-build="cross" data-slide="3"
                        src="/screenshots/rust-grid-inspector-light.png"
                        alt="The cross-platform Rust app's grid with the environment inspector"
                        width="2080" height="1360" loading="lazy" />
                    <!-- The LIVE build — not a screenshot: the real engine
                         (Rust → WASM) as an interactive REPL. Hydrates only
                         when Astro mounts the island; the carousel treats
                         this build as slide-less (no dots, no cycling, no
                         pause/maximize handlers). -->
                    <div class="shot-live" data-build="live">
                        <Repl client:only="preact" />
                    </div>
                </div>
                <div class="dots" aria-label="Screenshot navigation"></div>
            </div>
            <div class="lightbox" aria-hidden="true">
                <img class="lightbox-img" alt="" />
            </div>

            <script>
                // Theme-aware screenshot carousel. It cycles every shot for
                // the CURRENT theme (CSS hides the other theme), rebuilding
                // its dots when the theme toggles. Single click = pause/play;
                // double click = maximize; Esc / click-away / double-click
                // exits. Reduced-motion users start paused.
                const root = document.querySelector<HTMLElement>(".hero-shot[data-carousel]");
                const lightbox = document.querySelector<HTMLElement>(".lightbox");
                if (root && lightbox) {
                    const shots = root.querySelector<HTMLElement>(".shots")!;
                    const dotsWrap = root.querySelector<HTMLElement>(".dots")!;
                    const lightImg = lightbox.querySelector<HTMLImageElement>(".lightbox-img")!;
                    let index = 0;
                    let timer: number | undefined;
                    let clickTimer: number | undefined;
                    let wasPaused = false;
                    let paused = matchMedia("(prefers-reduced-motion: reduce)").matches;

                    const theme = () =>
                        document.documentElement.dataset.theme === "light" ? "light" : "dark";
                    // "native" | "cross" | "live" — live is the REPL island,
                    // a slide-less build (no dots/cycling/pause/maximize).
                    const build = () => root.dataset.build ?? "native";
                    const slides = () =>
                        [
                            ...root.querySelectorAll<HTMLImageElement>(
                                `.shot-${theme()}[data-build="${build()}"]`,
                            ),
                        ].sort((a, b) => Number(a.dataset.slide) - Number(b.dataset.slide));

                    const render = () => {
                        const list = slides();
                        if (list.length === 0) return; // live build: no slides
                        index = ((index % list.length) + list.length) % list.length;
                        root.querySelectorAll(".shot").forEach((s) => s.classList.remove("is-active"));
                        list[index]?.classList.add("is-active");
                        [...dotsWrap.children].forEach((d, k) =>
                            d.classList.toggle("is-active", k === index),
                        );
                    };
                    const buildDots = () => {
                        dotsWrap.innerHTML = "";
                        slides().forEach((_, k) => {
                            const b = document.createElement("button");
                            b.className = "dot" + (k === index ? " is-active" : "");
                            b.setAttribute("aria-label", `Show screenshot ${k + 1}`);
                            b.addEventListener("click", (e) => {
                                e.stopPropagation();
                                pause();
                                index = k;
                                render();
                            });
                            dotsWrap.appendChild(b);
                        });
                    };
                    const stop = () => {
                        if (timer) clearInterval(timer);
                        timer = undefined;
                    };
                    const play = () => {
                        stop();
                        if (!paused)
                            timer = window.setInterval(() => {
                                index += 1;
                                render();
                            }, 5500);
                    };
                    const pause = () => {
                        paused = true;
                        root.classList.add("is-paused");
                        stop();
                    };
                    const togglePlay = () => {
                        paused = !paused;
                        root.classList.toggle("is-paused", paused);
                        paused ? stop() : play();
                    };

                    const maximize = () => {
                        const list = slides();
                        if (list.length === 0) return; // live build
                        lightImg.src = list[index].src;
                        lightImg.alt = list[index].alt;
                        lightbox.classList.add("open");
                        lightbox.setAttribute("aria-hidden", "false");
                        wasPaused = paused;
                        pause();
                    };
                    const exitMax = () => {
                        if (!lightbox.classList.contains("open")) return;
                        lightbox.classList.remove("open");
                        lightbox.setAttribute("aria-hidden", "true");
                        paused = wasPaused;
                        root.classList.toggle("is-paused", paused);
                        play();
                    };

                    // Single click pauses/plays; a double click cancels the
                    // pending single action and maximizes instead.
                    shots.addEventListener("click", () => {
                        if (build() === "live") return; // REPL owns its clicks
                        clearTimeout(clickTimer);
                        clickTimer = window.setTimeout(togglePlay, 250);
                    });
                    shots.addEventListener("dblclick", () => {
                        if (build() === "live") return;
                        clearTimeout(clickTimer);
                        maximize();
                    });

                    lightbox.addEventListener("click", (e) => {
                        if (e.target === lightbox) exitMax(); // click away (backdrop)
                    });
                    lightbox.addEventListener("dblclick", exitMax);
                    document.addEventListener("keydown", (e) => {
                        if (e.key === "Escape") exitMax();
                    });

                    new MutationObserver(() => {
                        buildDots();
                        render();
                    }).observe(document.documentElement, {
                        attributes: true,
                        attributeFilter: ["data-theme"],
                    });

                    // Segmented build toggle: switch the native/cross set,
                    // reset to its first slide, and rebuild dots + track.
                    root.querySelectorAll<HTMLButtonElement>(".bt-opt").forEach((btn) => {
                        btn.addEventListener("click", (e) => {
                            e.stopPropagation();
                            const chosen = btn.dataset.build ?? "native";
                            if (root.dataset.build === chosen) return;
                            root.dataset.build = chosen;
                            root.querySelectorAll(".bt-opt").forEach((b) =>
                                b.classList.toggle(
                                    "is-active",
                                    (b as HTMLElement).dataset.build === chosen,
                                ),
                            );
                            index = 0;
                            buildDots();
                            render();
                            // The live build doesn't cycle; leaving it
                            // resumes (unless the visitor had paused).
                            chosen === "live" ? stop() : play();
                        });
                    });

                    buildDots();
                    render();
                    play();
                }
            </script>
        </section>

        <section id="features">
            <h2>Built around one idea: be exact, then stay out of the way</h2>
            <p class="section-lede">
                Ten things Soroban does well. Tap a card to expand it.
            </p>
            <div class="features summary">
                <Card title="Exact arithmetic" scopes={["log", "grid", "cli"]}>
                    A 50-digit exact decimal engine — <code>0.1 + 0.2</code> is
                    exactly <code>0.3</code> — plus a money type and checked
                    fixed-width integers.
                    <Fragment slot="detail">
                        <p>
                            Underneath everything is an arbitrary-precision
                            decimal engine. <code>+ − ×</code> and integer powers
                            are <em>exact</em>; division carries 50 significant
                            digits with banker's rounding. <code>0.1 + 0.2</code>
                            is exactly <code>0.3</code>, and Machin's 1706 formula
                            recovers π to 51 places in three typed lines — money
                            math never picks up floating-point drift.
                        </p>
                        <p>
                            When you need a <strong>bounded</strong> type, it
                            stays exact but <em>checked</em>.
                            <code>Decimal(10.5, 5, 2)</code> is <code>10.50</code>
                            — SQL <code>DECIMAL(p, s)</code>, the money type:
                            rounds to the scale, errors on precision overflow
                            instead of silently dropping digits (banker's
                            rounding, or <code>Rounding.HalfUp</code>).
                            <code>Int32(255)</code>, <code>UInt8(8)</code> are
                            integers at 8–256 bits, signed or unsigned —
                            <code>Int8(100) + Int8(100)</code> is an overflow
                            error, never a silent wraparound.
                        </p>
                        <p>
                            And the everyday formulas are built in across domains:
                            statistics (<code>median</code>, <code>stdev</code>),
                            algebra (<code>sqrt</code>, <code>gcd</code>), logic
                            (<code>if</code>, <code>and</code>, <code>or</code>),
                            finance (<code>pmt</code>, <code>irr</code>,
                            <code>xirr</code>), and dates (<code>edate</code>,
                            <code>days</code>).
                        </p>
                    </Fragment>
                </Card>
                <Card title="The Anzan language" scopes={["log", "grid", "cli"]}>
                    Custom functions, recursion, data structures, lambdas, and
                    namespaces — a real little language, fully specified.
                    <Fragment slot="detail">
                        <p>
                            <a href={links.spec}>Anzan</a> — Soroban's expression
                            language — is a small but real language. Define a
                            function and it's immediately usable:
                            <code>f(x) = x * 2</code>. Functions recurse, take
                            LaTeX-style reductions (<code>∑</code>/<code>∏</code>),
                            and document themselves from a trailing
                            <code># comment</code>.
                        </p>
                        <p>
                            It has first-class data — arrays, maps, strings,
                            booleans, and <code>data</code> records — plus
                            higher-order functions and lambdas
                            (<code>map(x -&gt; x^2, [1, 2, 3])</code>). Group your
                            own types and functions into
                            <strong>namespaces</strong> (<code>Geo::Point</code>,
                            <code>import Geo</code>), nesting and all. Every
                            built-in has a man page (<code>man pmt</code>, or ⌘/
                            for a searchable reference), and every documented
                            example is evaluated by the test suite — so the docs
                            can't rot.
                        </p>
                        <p>
                            <a class="button quiet" href={links.spec}>Read the language spec</a>
                        </p>
                    </Fragment>
                </Card>
                <Card title="Log + grid, one engine" scopes={["log", "grid"]}>
                    A scrolling calculator log and a 26×1,000 grid that share
                    every variable, function, and cell reference.
                    <Fragment slot="detail">
                        <p>
                            Type into a scrolling calculation log, or flip to a
                            26×1,000 spreadsheet grid (⌘\). They share one engine:
                            reference <code>B:1</code> from the log, use
                            <code>rate</code> in a cell, sum a column with
                            <code>sum(A:1..A:9)</code> — across worksheets too
                            (<code>Budget!A:1</code>).
                        </p>
                        <p>
                            Name a cell and write <code>'Projected Rate' * 12</code>
                            instead of <code>B:7</code>; renames rewrite every
                            referencing formula. A formula can even inspect the
                            workbook itself — <code>cell("A", 1).value</code>,
                            <code>Workbook.worksheets["Budget"]</code>,
                            <code>sheetNames()</code> — with reads kept live, and
                            log commands like <code>updateCell</code> /
                            <code>addWorksheet</code> changing it one undo step at
                            a time.
                        </p>
                    </Fragment>
                </Card>
                <Card title="Programmer mode & bit editor" scopes={["log", "grid", "cli"]}>
                    A C-style dialect and a clickable binary bit editor with
                    reusable, color-coded bit-field formats.
                    <Fragment slot="detail">
                        <p>
                            Flip the log to <strong>Programmer mode</strong> and
                            the overloaded glyphs read like C: <code>^</code> is
                            XOR, <code>&amp;</code> <code>|</code>
                            <code>&lt;&lt;</code> <code>&gt;&gt;</code>
                            <code>~</code> are bitwise, <code>%</code> is modulo.
                            It's a display <em>dialect</em>, not a semantic switch
                            — the stored formula stays canonical, so it can never
                            mean two things. <code>:mode programmer</code> in the
                            CLI; a picker in the app.
                        </p>
                        <p>
                            The app adds a macOS-Calculator-style <strong>binary
                            bit editor</strong>: a number becomes a clickable
                            register, and a reusable <strong>bit-field
                            format</strong> labels its bit ranges — numeric,
                            per-bit flags (<code>r-x</code>), or an enum that
                            decodes a value to a label. Build one visually: drag
                            the bits to carve a group, name it, color it, and save.
                            Formats persist as ordinary typed values you can read
                            and edit.
                        </p>
                    </Fragment>
                </Card>
                <Card title="Currency as a type · Scientific mode" scopes={["log", "grid", "cli"]}>
                    Type money like you write it — <code>$10,000 + ($15,000 * 5%)</code>
                    is <code>$10,750.00</code> — in every mode, with currency as
                    a real type.
                    <Fragment slot="detail">
                        <p>
                            Money reads the way you'd write it on paper — no mode
                            switch needed: <code>$10 * 5%</code> is
                            <code>$0.50</code>, <code>€10 * .4</code> is
                            <code>€4.00</code>, and thousands group with commas —
                            <code>138,561 * 9%</code> answers
                            <code>12,470.49</code>, echoing your grouping back.
                        </p>
                        <p>
                            The currency is a <em>type</em>, not decoration. It
                            rides the value through arithmetic — a money input
                            always answers as money, rendered grouped at two
                            decimals with the symbol outside the sign
                            (<code>-$1,234.50</code>) — and mixing currencies
                            (<code>$10 + €5</code>) is a loud error, never a
                            guess. Ten currencies from <code>$</code> to
                            <code>₿</code>; the constructor
                            <code>Money(10, "USD")</code> is what persists,
                            exactly like <code>Decimal(…)</code> and
                            <code>Int32(…)</code>. Nothing existing changes
                            meaning: <code>$A:1</code> still pins a cell
                            reference, and <code>max(138,561)</code> is still two
                            arguments — the separator always wins inside a call.
                        </p>
                        <p>
                            And alongside Programmer sits <strong>Scientific
                            mode</strong>: plain numeric results echo in
                            scientific notation (<code>123456 * 2</code> answers
                            <code>2.46912e5</code>) at the value's own
                            significant digits — never rounded — with an
                            engineering variant (<code>:mode scientific eng</code>
                            → <code>246.912e3</code>). The <code>°</code> degree
                            literal works in every mode: <code>sin(90°)</code> is
                            exactly <code>1</code>.
                        </p>
                    </Fragment>
                </Card>
                <Card title="Live what-if controls" scopes={["grid"]}>
                    Sliders, steppers, checkboxes, and dropdowns right in the
                    cells — the model recalculates as you drag.
                    <Fragment slot="detail">
                        <p>
                            <code>rate = slider(0.08, 0, 0.2)</code> renders as a
                            draggable slider right in its cell — plus steppers,
                            checkboxes, and dropdowns. The whole model
                            recalculates as you drag, with one undo step on
                            release. The control's value <em>is</em> the stored
                            literal, so it's still a plain, inspectable formula.
                        </p>
                    </Fragment>
                </Card>
                <Card title="Data sheets at scale" scopes={["grid"]}>
                    Import 100,000-row CSVs into SQLite-backed sheets; formulas
                    reach every row, opens stay instant.
                    <Fragment slot="detail">
                        <p>
                            Import a 100,000-row CSV into a SQLite-backed sheet
                            that lives inside the document. Formulas reach every
                            row (<code>sum(Sales!C:2..C:100000)</code>), and opens
                            stay instant — the grid renders a window, the database
                            holds the rows.
                        </p>
                    </Fragment>
                </Card>
                <Card title="In your terminal" scopes={["cli"]}>
                    The whole language ships as a <code>soroban</code> CLI:
                    REPL, pipes, and real exit codes.
                    <Fragment slot="detail">
                        <p>
                            The full language ships as a <code>soroban</code> CLI.
                            Run it as an Anzan REPL with tab completion, signature
                            hints, and persistent history; pass an expression as an
                            argument; or pipe it
                            (<code>echo "fact(25)" | soroban</code>) and script
                            against real exit codes. Same engine, same
                            column-accurate error carets — just no grid.
                        </p>
                    </Fragment>
                </Card>
                <Card title="A plain file format" scopes={["log", "grid"]}>
                    <code>.soroban</code> is documented JSON (+ SQLite) —
                    diffable, scriptable, hand-editable. CSV in and out.
                    <Fragment slot="detail">
                        <p>
                            <code>.soroban</code> is a documented package of
                            pretty-printed JSON (plus SQLite for data sheets) —
                            diffable in git, scriptable, hand-editable. Every
                            behavior of the format is written down, and CSV goes in
                            and out. Your work isn't trapped in a binary blob.
                        </p>
                    </Fragment>
                </Card>
                <Card title="Make it yours">
                    Ten built-in themes, or drop in your own. This very site is
                    wearing two of them.
                    <Fragment slot="detail">
                        <p>
                            Ten built-in themes — Solarized, Dracula, Nord,
                            gruvbox… — or drop a small JSON theme into Application
                            Support to make your own. This very site is wearing two
                            of them; toggle it in the header.
                        </p>
                    </Fragment>
                </Card>
            </div>
        </section>

        <section class="support" id="source">
            <div class="cols">
                <div>
                    <h2>Open source</h2>
                    <p>
                        Soroban is developed in the open — and it's
                        <strong> two engines, one shared spec</strong>: a native
                        Swift build and a cross-platform Rust build, both
                        standalone and UI-free, verified against the same
                        executable Gherkin specification — including the
                        mathematical identities that certify it (π via Machin,
                        Nicomachus, the Gregorian leap rule…). Read it, audit
                        it, build it yourself.
                    </p>
                    <p>
                        <a class="button quiet" href={links.source}
                            >Source &amp; issues</a
                        >
                    </p>
                </div>
                <div id="donate">
                    <h2>Donations</h2>
                    <p>
                        The app is free and always will be. If it earns a place
                        in your workflow, a donation keeps the work moving — and
                        is genuinely appreciated.
                    </p>
                    <p style="display:flex; gap:0.6rem; flex-wrap:wrap">
                        <a class="button primary" href={links.donate}
                            >Buy me a coffee</a
                        >
                    </p>
                </div>
            </div>
        </section>
    </div>
</Layout>
